/* Client Page Styles */
:root {
    --primary-color: #2563eb;
    --primary-light: #dbeafe;
    --secondary-color: #64748b;
    --success-color: #10b981;
    --warning-color: #f59e0b;
    --danger-color: #ef4444;
    --background-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    --card-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    --input-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    --border-radius: 12px;
    --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
}

/* Reset for client page */
html, body {
    font-family: 'Inter', sans-serif;
    background-color: #f8f9fa;
    min-height: 100vh;
    margin: 0 !important;
    padding: 0 !important;
}

.container-fluid {
    padding: 0 !important;
    margin: 0 !important;
    height: 100vh;
}

.main-client-container {
    background: transparent;
    border-radius: 0;
    margin: 0 !important;
    box-shadow: none;
    min-height: 100vh;
    overflow: hidden;
}

.row.flex-nowrap {
    margin: 0 !important;
    height: 100vh;
}

/* Animations */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes slideInLeft {
    from {
        opacity: 0;
        transform: translateX(-30px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

/* Modern Card */
.client-card {
    background: transparent;
    border: none !important;
    border-radius: 0;
    box-shadow: none;
    animation: fadeInUp 0.6s ease-out;
    margin: 0;
    overflow: hidden;
}

.client-card-header {
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    padding: 2rem;
    border-radius: var(--border-radius) var(--border-radius) 0 0 !important;
    border: none !important;
}

.client-card-body {
    padding: 2rem;
    overflow-y: auto;
    overflow-x: hidden;
    height: calc(100vh - 160px);
}

/* Tab Navigation - Zone Style */
.client-nav-tabs {
    border: none;
    gap: 0;
    background: #e9ecef;
    border-radius: 8px;
    padding: 4px;
}

.client-nav-tab {
    background: transparent;
    border: none !important;
    border-radius: 6px !important;
    padding: 0.75rem 1.5rem;
    color: #6c757d;
    text-decoration: none !important;
    font-weight: 600;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    margin: 0;
}

.client-nav-tab:hover {
    background: rgba(0, 123, 255, 0.1);
    color: var(--primary-color);
    text-decoration: none !important;
}

.client-nav-tab.active {
    background: var(--primary-color);
    color: white !important;
    text-decoration: none !important;
    box-shadow: 0 2px 4px rgba(0, 123, 255, 0.3);
}

/* Action Buttons */
.action-buttons {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    animation: slideInLeft 0.6s ease-out 0.1s both;
}

.btn-modern {
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: none;
    box-shadow: var(--shadow-sm);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none !important;
}

.btn-modern:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    text-decoration: none !important;
}

.btn-modern.btn-warning {
    background: linear-gradient(135deg, var(--warning-color) 0%, #f59e0b 100%);
    color: white;
    text-decoration: none !important;
}

.btn-modern.btn-warning:hover {
    color: white;
    text-decoration: none !important;
}

.btn-modern.btn-secondary {
    background: linear-gradient(135deg, var(--secondary-color) 0%, #4b5563 100%);
    color: white;
    text-decoration: none !important;
}

.btn-modern.btn-secondary:hover {
    color: white;
    text-decoration: none !important;
}

.btn-modern.btn-success {
    background: linear-gradient(135deg, var(--success-color) 0%, #10b981 100%);
    color: white;
    text-decoration: none !important;
}

.btn-modern.btn-success:hover {
    background: linear-gradient(135deg, #1e7e34 0%, #059669 100%);
    color: white;
    text-decoration: none !important;
}

/* Modern Table - Remove border */
.table-modern {
    background: white;
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    border: none;
    animation: slideInLeft 0.6s ease-out 0.2s both;
}

.table-modern .table {
    margin-bottom: 0;
}

.table-modern thead th {
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    font-weight: 600;
    color: var(--dark-color);
    padding: 1rem;
    border: none;
}

.table-modern tbody td {
    padding: 1rem;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
}

.table-modern tbody tr {
    transition: all 0.2s ease;
}

.table-modern tbody tr:hover {
    background: #f8fafc;
    transform: scale(1.01);
}

/* Action Buttons in Table */
.btn-action {
    padding: 0.5rem;
    border-radius: 6px;
    border: none;
    transition: all 0.3s ease;
    margin: 0 0.25rem;
    box-shadow: var(--shadow-sm);
    color: white;
    text-decoration: none;
}

.btn-action:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
    color: white;
}

.btn-action.btn-primary {
    background: var(--primary-color);
}

.btn-action.btn-primary:hover {
    background: #0056b3;
}

.btn-action.btn-danger {
    background: var(--danger-color);
}

.btn-action.btn-danger:hover {
    background: #c82333;
}

/* Status Icons */
.status-icon {
    font-size: 1.2rem;
}

/* Modern Modal */
.modal-modern .modal-content {
    border: none;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-lg);
}

.modal-modern .modal-header {
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    border-bottom: 1px solid #e2e8f0;
    border-radius: var(--border-radius) var(--border-radius) 0 0;
    padding: 1.5rem;
}

.modal-modern .modal-title {
    font-weight: 600;
    color: var(--dark-color);
}

.modal-modern .modal-body {
    padding: 2rem;
}

.modal-modern .modal-footer {
    border-top: 1px solid #e2e8f0;
    padding: 1.5rem;
}

/* Champs de formulaire minimalistes */
.form-floating > .form-control,
.form-floating > .form-select {
    border: 1px solid #ced4da;
    border-radius: 0;
    padding: 0.5rem 0.75rem;
    background: transparent;
    transition: border-color 0.3s ease;
}

.form-floating > .form-control:focus,
.form-floating > .form-select:focus {
    border-color: #007bff;
    box-shadow: none;
}

.form-floating > label {
    color: #6c757d;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.3s ease;
}

.form-floating > .form-control:focus + label,
.form-floating > .form-select:focus + label {
    color: #007bff;
}

/* Suppression des bordures arrondies */
.form-control,
.form-select {
    border-radius: 0;
}

/* Style des boutons minimalistes */
.btn {
    border-radius: 0;
    font-weight: 500;
    padding: 0.5rem 1rem;
    transition: background-color 0.3s ease, border-color 0.3s ease;
}

.btn-primary {
    background-color: #007bff;
    border-color: #007bff;
    color: #fff;
}

.btn-primary:hover {
    background-color: #0056b3;
    border-color: #0056b3;
}

.btn-secondary {
    background-color: #6c757d;
    border-color: #6c757d;
    color: #fff;
}

.btn-secondary:hover {
    background-color: #5a6268;
    border-color: #5a6268;
}

/* Modern Form Styles */
.form-header {
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    border-radius: var(--border-radius);
    padding: 2rem;
    margin-bottom: 2rem;
    border: 1px solid #e2e8f0;
    animation: fadeInUp 0.6s ease-out;
}

.form-title {
    margin: 0;
    font-weight: 600;
    color: var(--dark-color);
    font-size: 1.5rem;
}

.modern-form {
    animation: slideInLeft 0.6s ease-out 0.2s both;
}

.form-section {
    background: white;
    border-radius: var(--border-radius);
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid #e5e7eb;
    animation: scaleIn 0.6s ease-out;
}

.section-title {
    color: var(--dark-color);
    font-weight: 600;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
}
/* Responsive Design */
@media (max-width: 768px) {
    .client-card {
        margin: 10px;
        border-radius: 8px;
    }

    .client-card-header,
    .client-card-body {
        padding: 1rem;
    }

    .action-buttons {
        flex-direction: column;
    }

    .btn-modern {
        width: 100%;
        justify-content: center;
    }

    .table-responsive {
        border-radius: 8px;
    }
}

.form-check-input {
    width: 3rem;
    height: 1.5rem;
}

.form-check-label {
    margin-left: 0.5rem;
    font-size: 1.1rem;
}

/* Boutons d'action */
.action-buttons {
    display: flex;
    gap: 0.75rem;
    align-items: center;
}

.btn {
    border-radius: var(--border-radius);
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    transition: var(--transition);
    border-width: 2px;
}

.btn-primary {
    background: linear-gradient(135deg, var(--primary-color), #1e40af);
    border-color: var(--primary-color);
    box-shadow: var(--input-shadow);
}

.btn-primary:hover {
    background: linear-gradient(135deg, #1e40af, #1e3a8a);
    border-color: #1e40af;
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(37, 99, 235, 0.3);
}

.btn-outline-secondary {
    border-color: var(--secondary-color);
    color: var(--secondary-color);
}

.btn-outline-secondary:hover {
    background: var(--secondary-color);
    border-color: var(--secondary-color);
    color: white;
}

/* Animations pour les champs obligatoires */
.enhanced-input:required:invalid {
    border-color: rgba(239, 68, 68, 0.3);
}

.enhanced-input:required:valid {
    border-color: rgba(16, 185, 129, 0.3);
}

/* Responsive Design */
@media (max-width: 768px) {
    .form-container {
        margin: 1rem;
        border-radius: var(--border-radius);
    }

    .form-header {
        padding: 2rem 1rem;
    }

    .header-title {
        font-size: 1.5rem;
    }

    .enhanced-form {
        padding: 1rem;
    }

    .form-section {
        padding: 1rem;
        margin-bottom: 1.5rem;
    }

    .section-header {
        flex-direction: column;
        text-align: center;
        gap: 0.5rem;
    }

    .action-buttons {
        flex-direction: column;
        width: 100%;
    }

    .action-buttons .btn {
        width: 100%;
    }
}

/* Conteneur principal du formulaire */
.form-container {
    max-width: 1200px;
    width: 100%;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border-radius: var(--border-radius);
    box-shadow: var(--card-shadow);
    overflow: hidden;
    animation: slideIn 0.6s ease-out;
    margin: 2rem auto;
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* En-tête du formulaire */
.form-header {
    background: linear-gradient(135deg, var(--primary-color) 0%, #1e40af 100%);
    color: white;
    padding: 1.5rem 2rem;
    position: relative;
    overflow: hidden;
}

.form-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="50" cy="50" r="1" fill="rgba(255,255,255,0.1)"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
    opacity: 0.3;
}

.header-icon {
    font-size: 1.5rem;
    margin-right: 1rem;
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.2);
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
}

.header-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0;
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    height: 2.5rem;
}

/* Formulaire amélioré */
.enhanced-form {
    padding: 2rem;
}

/* Sections du formulaire */
.form-section {
    margin-bottom: 1.5rem;
    padding: 1.5rem;
    border-radius: var(--border-radius);
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(226, 232, 240, 0.8);
    transition: var(--transition);
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
}

.form-section:hover {
    background: white;
    border-color: rgba(99, 102, 241, 0.5);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

/* En-têtes de section */
.section-header {
    display: flex;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(203, 213, 224, 0.5);
}

.section-icon {
    font-size: 1.25rem;
    color: var(--primary-color);
    margin-right: 0.75rem;
    background: var(--primary-light);
    padding: 0.5rem;
    border-radius: 0.5rem;
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.section-title {
    color: var(--primary-color);
    font-weight: 600;
    margin: 0;
    font-size: 1.1rem;
    letter-spacing: -0.01em;
}

/* Groupes d'input personnalisés */
.input-group-custom {
    position: relative;
    margin-bottom: 0.5rem;
}

.input-icon {
    position: absolute;
    top: 50%;
    left: 1rem;
    transform: translateY(-50%);
    color: var(--secondary-color);
    z-index: 10;
    font-size: 1.1rem;
    transition: all 0.3s ease;
}

/* Inputs améliorés */
.enhanced-input {
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    padding: 0.75rem 1rem 0.75rem 3rem !important;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #2d3748;
    background: white;
    transition: var(--transition);
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    height: auto;
    line-height: 1.5;
}

.enhanced-input:focus {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    outline: none;
}

.enhanced-input::placeholder {
    color: #a0aec0;
    font-weight: 400;
}

textarea.enhanced-input {
    min-height: 120px;
    padding-top: 1rem !important;
    resize: vertical;
}

.enhanced-input:focus {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1), 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    background: white;
}

.enhanced-input:focus + label {
    color: var(--primary-color);
}

.input-group-custom:focus-within .input-icon {
    color: var(--primary-color);
    transform: translateY(-50%) scale(1.1);
}

/* Labels flottants */
.form-floating > label {
    color: var(--secondary-color);
    font-weight: 500;
    padding-left: 3rem;
    transition: all 0.2s ease;
}

/* Téléversement de fichiers */
.file-upload-wrapper {
    position: relative;
    margin-bottom: 1rem;
}

.file-input {
    position: absolute;
    left: -9999px;
    opacity: 0;
}

.file-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    border: 2px dashed #cbd5e0;
    border-radius: var(--border-radius);
    background: #f8fafc;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
}

.file-label:hover {
    border-color: var(--primary-color);
    background: #f0f7ff;
}

.file-label i {
    font-size: 2rem;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
}

.file-info {
    font-size: 0.875rem;
    color: var(--secondary-color);
    margin-top: 0.5rem;
}

/* Bouton d'ajout de document */
.btn-add-document {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--primary-color);
    background: rgba(37, 99, 235, 0.1);
    border: 1px dashed var(--primary-color);
    transition: var(--transition);
}

.btn-add-document:hover {
    background: rgba(37, 99, 235, 0.15);
    color: var(--primary-color);
    transform: translateY(-1px);
}

.btn-add-document i {
    font-size: 1.1em;
}

/* Style pour les sélecteurs */
select.form-select.enhanced-input {
    appearance: none;
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2 5l6 6 6-6'/%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 0.75rem center;
    background-size: 16px 12px;
    padding-right: 2.5rem !important;
}

/* Style pour le switch */
.form-switch .form-check-input {
    width: 3em;
    height: 1.5em;
    margin-right: 0.5rem;
}

.form-switch .form-check-input:checked {
    background-color: var(--success-color);
    border-color: var(--success-color);
}

/* Animation pour les champs obligatoires */
@keyframes shake {
    0%, 100% { transform: translateX(0); }
    20%, 60% { transform: translateX(-5px); }
    40%, 80% { transform: translateX(5px); }
}

.is-invalid {
    border-color: #f87171 !important;
    animation: shake 0.5s ease-in-out;
}

.is-valid {
    border-color: #34d399 !important;
}

/* Styles responsifs supplémentaires */
@media (max-width: 768px) {
    .form-container {
        margin: 0.5rem;
        border-radius: 0.75rem;
    }
    
    .form-header {
        padding: 1rem;
    }
    
    .header-title {
        font-size: 1.1rem;
    }
    
    .header-icon {
        font-size: 1.25rem;
        width: 2rem;
        height: 2rem;
    }
    
    .enhanced-form {
        padding: 1rem;
    }
    
    .form-section {
        padding: 1rem;
        margin-bottom: 1rem;
    }
    
    .section-title {
        font-size: 1rem;
    }
    
    .section-icon {
        width: 2rem;
        height: 2rem;
        font-size: 1rem;
    }
    
    .action-buttons {
        flex-direction: column;
        gap: 0.5rem;
    }
    
    .action-buttons .btn {
        width: 100%;
        margin: 0;
    }
    
    .enhanced-input {
        padding: 0.65rem 0.75rem 0.65rem 2.75rem !important;
        font-size: 0.9375rem;
    }
    
    .input-icon {
        left: 0.75rem;
        font-size: 1rem;
    }
}
