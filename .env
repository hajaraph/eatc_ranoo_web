# Exemple de fichier .env pour Ranoo Web

# Clé secrète Django (à personnaliser !)
SECRET_KEY=remplacez-moi-par-une-cle-secrete

# Environnement (development ou production)
DJANGO_ENV=development

# Hôtes autorisés (séparés par des virgules, sans espaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# Configuration de la base de données PostgreSQL
POSTGRES_DB=rel_compteur
POSTGRES_USER=postgres
POSTGRES_PASSWORD=motdepasse
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Origines autorisées pour CORS (séparées par des virgules)
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Origines de confiance pour CSRF (séparées par des virgules)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Configuration Celery (optionnel)
# CELERY_BROKER_URL=redis://localhost:6379
# CELERY_RESULT_BACKEND=django-db
